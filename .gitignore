# ========================================
# EmoAgent v1 - Git 忽略规则
# ========================================

# ---------- 环境变量 ----------
.env
.env.local
.env.development
.env.testing
.env.production

# ---------- Python ----------
__pycache__/
*.py[cod]
*$py.class
*.so
.venv/
venv/
env/
*.egg-info/
dist/
build/
*.egg
.mypy_cache/

# ---------- AI 模型文件 ----------
/models/
*.bin
*.pt
*.pth
*.onnx
*.safetensors

# ---------- 日志 ----------
logs/
*.log

# ---------- 数据库 ----------
*.db
*.sqlite3

# ---------- IDE ----------
.vscode/
.idea/
*.swp
*.swo
*~
.cursor/

# ---------- 系统文件 ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- Node.js / 前端 ----------
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/.env.development
frontend/.env.production
frontend/.env.staging

# ---------- 测试与覆盖率 ----------
.coverage
htmlcov/
.pytest_cache/
coverage.xml
frontend/coverage/

# ---------- Docker ----------
docker-compose.override.yml

# ---------- 安全敏感文件 ----------
*.pem
*.key

# ---------- 备份 ----------
*.backup
*.bak

# ---------- Alembic ----------
# 保留迁移文件，但忽略自动生成的临时文件
alembic/versions/__pycache__/
