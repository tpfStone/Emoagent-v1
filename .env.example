# ========================================
# 情绪对话系统 - 后端环境配置模板
# ========================================
# 
# 使用说明：
# 1. 复制此文件为 .env: cp .env.example .env
# 2. 填写实际的配置值（不要提交 .env 到 Git）
# 3. 重启应用使配置生效
#
# ========================================

# ========== 数据库配置 ==========
# PostgreSQL 连接字符串
# 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://emoagent_user:your_secure_password@localhost:5432/emoagent

# PostgreSQL 详细配置（用于 Docker Compose）
POSTGRES_USER=emoagent_user
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=emoagent
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ========== Redis 配置 ==========
# Redis 连接字符串
REDIS_URL=redis://localhost:6379/0

# Redis 密码（可选，本地开发可留空）
REDIS_PASSWORD=

# Redis 主机和端口（用于 Docker Compose）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ========== LLM 配置 ==========
# LLM 提供商选择
# 可选值: mock | deepseek | qianwen | wenxin
# 
# 开发过程分阶段接入 LLM：
# 开发阶段：mock（免费，方便本地开发调试） ✅ 推荐开始
# 测试阶段：deepseek（替换为真实 LLM，验证端到端效果）
# 生产阶段：qianwen/wenxin 等（按需评估切换）
LLM_PROVIDER=mock

# ===== DeepSeek API 配置（第二阶段使用） =====
# 获取 API Key: https://platform.deepseek.com/
# 注意：Mock 模式下无需配置 API Key
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ===== 通义千问 API 配置（备选） =====
# 获取 API Key: https://dashscope.console.aliyun.com/
QIANWEN_API_KEY=

# ===== 文心一言 API 配置（备选） =====
# 获取 API Key: https://console.bce.baidu.com/qianfan/
WENXIN_API_KEY=
WENXIN_SECRET_KEY=

# ===== LLM 通用配置 =====
# LLM 超时时间（秒）
LLM_TIMEOUT=10
# LLM 默认温度参数（0-1）
LLM_TEMPERATURE=0.7
# LLM 最大生成 token 数
LLM_MAX_TOKENS=1000

# ========== BERT 模型配置 ==========
# BERT 模型路径（本地路径或 HuggingFace model ID）
# 使用 nateraw/bert-base-uncased-emotion 模型，支持 6 种情绪分类：
# sadness, joy, love, anger, fear, surprise
BERT_MODEL_PATH=./models/bert-emotion
BERT_MODEL_NAME=nateraw/bert-base-uncased-emotion

# BERT 推理设备（cpu | cuda）
BERT_DEVICE=cpu

# 是否启用 BERT 推理加速
BERT_USE_FP16=false

# ========== 应用配置 ==========
# 运行环境（development | staging | production）
ENV=development

# 调试模式（true | false）
DEBUG=true

# 日志级别（DEBUG | INFO | WARNING | ERROR | CRITICAL）
LOG_LEVEL=INFO

# 应用密钥（用于签名，生产环境必须修改）
SECRET_KEY=your-secret-key-change-in-production

# 服务器配置
HOST=0.0.0.0
PORT=8000

# Uvicorn 工作进程数（生产环境建议 4-8）
WORKERS=4

# ========== CORS 配置 ==========
# 允许跨域的源（逗号分隔，生产环境务必配置）
# 示例: https://your-domain.com,https://www.your-domain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# 是否允许凭证（cookies）
CORS_ALLOW_CREDENTIALS=true

# 允许的 HTTP 方法
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS

# 允许的请求头
CORS_ALLOW_HEADERS=*

# ========== 短期记忆配置 ==========
# Redis 记忆 TTL（秒，默认 24 小时）
MEMORY_TTL=86400

# 短期记忆最大轮数
MEMORY_MAX_TURNS=6

# ========== 危机干预配置 ==========
# 危机规则缓存时间（秒，默认 1 小时）
CRISIS_RULES_CACHE_TTL=3600

# 是否启用危机干预
CRISIS_DETECTION_ENABLED=true

# ========== 监控与日志配置（可选） ==========
# Sentry DSN（错误追踪）
SENTRY_DSN=

# Sentry 环境标识
SENTRY_ENVIRONMENT=development

# 是否启用 Prometheus 指标
ENABLE_METRICS=false

# 日志文件路径
LOG_FILE_PATH=./logs/app.log

# ========== 速率限制配置（可选） ==========
# 是否启用速率限制
RATE_LIMIT_ENABLED=true

# 每个 session 每分钟最大请求数
RATE_LIMIT_PER_MINUTE=60

# ========== 数据库连接池配置 ==========
# 连接池大小
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# 连接超时（秒）
DB_POOL_TIMEOUT=30

# ========== 功能开关（可选） ==========
# 是否启用 API 文档（生产环境建议关闭）
ENABLE_API_DOCS=true

# 是否启用 BERT 情绪识别（如果关闭，返回默认情绪）
ENABLE_EMOTION_DETECTION=true

# 是否记录完整的对话内容到日志（调试用）
LOG_FULL_MESSAGES=false

# ========== 第三方服务配置（可选） ==========
# 短信服务（用于危机干预通知）
SMS_API_KEY=
SMS_API_SECRET=

# 邮件服务（用于报警）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# ========== 开发工具配置（可选） ==========
# 是否启用热重载（开发环境）
RELOAD=true

# 是否启用访问日志
ACCESS_LOG=true

# ========== 说明 ==========
# 1. 所有包含 "your-" 前缀的值必须替换为实际值
# 2. 密码类配置使用强密码（至少 16 位，包含大小写字母、数字、特殊字符）
# 3. 生产环境务必修改 SECRET_KEY 和所有默认密码
# 4. API Key 等敏感信息不要提交到版本控制系统
# 5. 使用 Docker Compose 时，部分配置会被 docker-compose.yml 覆盖
