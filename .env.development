# ========================================
# 情绪对话系统 - 开发环境配置
# ========================================

# ========== 数据库配置 ==========
DATABASE_URL=postgresql://emoagent_user:dev_password@localhost:5432/emoagent_dev
POSTGRES_USER=emoagent_user
POSTGRES_PASSWORD=dev_password
POSTGRES_DB=emoagent_dev

# ========== Redis 配置 ==========
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ========== LLM 配置 ==========
LLM_PROVIDER=mock
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TIMEOUT=10.0
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000

# ========== BERT 模型配置 ==========
BERT_MODEL_PATH=./models/bert-emotion
BERT_MODEL_NAME=nateraw/bert-base-uncased-emotion
BERT_DEVICE=cpu
ENABLE_EMOTION_DETECTION=true

# ========== 应用配置 ==========
ENV=development
DEBUG=true
LOG_LEVEL=DEBUG
SECRET_KEY=dev-secret-key-not-for-production
HOST=0.0.0.0
PORT=8200

# ========== CORS 配置 ==========
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174

# ========== 短期记忆配置 ==========
MEMORY_TTL=86400
MEMORY_MAX_TURNS=6

# ========== 危机干预配置 ==========
CRISIS_RULES_CACHE_TTL=3600
CRISIS_DETECTION_ENABLED=true

# ========== 监控与日志配置 ==========
ENABLE_METRICS=true
ENABLE_API_DOCS=true
LOG_FULL_MESSAGES=true

# ========== 数据库连接池配置 ==========
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
