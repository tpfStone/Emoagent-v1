# ========================================
# 情绪对话系统 - 生产环境配置
# ========================================
# 重要：所有密码和API Key必须替换为实际值

# ========== 数据库配置 ==========
DATABASE_URL=postgresql://emoagent_user:CHANGE_THIS_PASSWORD@postgres:5432/emoagent
POSTGRES_USER=emoagent_user
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD
POSTGRES_DB=emoagent

# ========== Redis 配置 ==========
REDIS_URL=redis://:CHANGE_THIS_PASSWORD@redis:6379/0
REDIS_PASSWORD=CHANGE_THIS_PASSWORD

# ========== LLM 配置 ==========
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=CHANGE_THIS_API_KEY
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TIMEOUT=10.0
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000

# ========== BERT 模型配置 ==========
BERT_MODEL_PATH=./models/bert-emotion
BERT_MODEL_NAME=nateraw/bert-base-uncased-emotion
BERT_DEVICE=cpu
ENABLE_EMOTION_DETECTION=true

# ========== 应用配置 ==========
ENV=production
DEBUG=false
LOG_LEVEL=WARNING
SECRET_KEY=CHANGE_THIS_SECRET_KEY_TO_RANDOM_STRING
HOST=0.0.0.0
PORT=8000

# ========== CORS 配置 ==========
CORS_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ========== 短期记忆配置 ==========
MEMORY_TTL=86400
MEMORY_MAX_TURNS=6

# ========== 危机干预配置 ==========
CRISIS_RULES_CACHE_TTL=3600
CRISIS_DETECTION_ENABLED=true

# ========== 监控与日志配置 ==========
ENABLE_METRICS=true
ENABLE_API_DOCS=false
LOG_FULL_MESSAGES=false

# ========== 数据库连接池配置 ==========
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ========== Grafana 配置 ==========
GRAFANA_PASSWORD=CHANGE_THIS_PASSWORD
