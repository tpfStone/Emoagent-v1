# ========================================
# 情绪对话系统 - 测试环境配置
# ========================================

# ========== 数据库配置 ==========
DATABASE_URL=postgresql://test_user:test_password@localhost:5432/emoagent_test
POSTGRES_USER=test_user
POSTGRES_PASSWORD=test_password
POSTGRES_DB=emoagent_test

# ========== Redis 配置 ==========
REDIS_URL=redis://localhost:6379/1
REDIS_PASSWORD=

# ========== LLM 配置 ==========
LLM_PROVIDER=mock
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
LLM_TIMEOUT=5.0
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=500

# ========== BERT 模型配置 ==========
BERT_MODEL_PATH=./models/bert-emotion
BERT_MODEL_NAME=nateraw/bert-base-uncased-emotion
BERT_DEVICE=cpu
ENABLE_EMOTION_DETECTION=false

# ========== 应用配置 ==========
ENV=testing
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=test-secret-key
HOST=0.0.0.0
PORT=8200

# ========== CORS 配置 ==========
CORS_ORIGINS=http://localhost:5173

# ========== 短期记忆配置 ==========
MEMORY_TTL=3600
MEMORY_MAX_TURNS=6

# ========== 危机干预配置 ==========
CRISIS_RULES_CACHE_TTL=3600
CRISIS_DETECTION_ENABLED=true

# ========== 监控与日志配置 ==========
ENABLE_METRICS=false
ENABLE_API_DOCS=true
LOG_FULL_MESSAGES=false

# ========== 数据库连接池配置 ==========
DB_POOL_SIZE=3
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=10
